[project]
sub_id = "53a229df"
name = "script-workshop"
requires = ["nodejs-24"]
project_type = "web"
entrypoint = "server.js"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "scripts/coze-preview-build.sh"]
run = ["bash", "scripts/coze-preview-run.sh"]

[deploy]
build = ["bash", ".cozeproj/scripts/deploy_build.sh"]
run = ["bash", ".cozeproj/scripts/deploy_run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"

[deploy.backend]
enabled = true

[subprojects]
path = ["."]
