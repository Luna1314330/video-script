# Coze（上线只需配置 COZE_API_TOKEN，工作流 ID 已写死在代码中）
# COZE_API_TOKEN=
# COZE_BASE_URL=https://api.coze.cn

# 腾讯云 MySQL
# DATABASE_URL=mysql://用户名:密码@主机:3306/数据库名

# JWT 认证（至少 32 位随机字符串）
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=7d

# 后台管理登录（可选，默认 admin / 19910113）
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=19910113
# ADMIN_SESSION_SECRET=change-me-in-production
# HTTP 部署（如 http://IP）保持 false；HTTPS 可设 true 或配置 APP_URL=https://你的域名
# ADMIN_COOKIE_SECURE=false
# APP_URL=http://150.158.33.156

# 微信支付（API v3，备案域名 + HTTPS 就绪后填写）
# WECHAT_PAY_MCH_ID=16xxxxxxxx
# WECHAT_PAY_APP_ID=wxxxxxxxxxx
# WECHAT_PAY_API_V3_KEY=32位APIv3密钥
# WECHAT_PAY_SERIAL_NO=商户证书序列号
# WECHAT_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# 或 WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
# WECHAT_PAY_PLATFORM_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# WECHAT_PAY_NOTIFY_URL=https://你的域名/api/payments/wechat/notify
# 本地/未备案前测试可开启模拟支付（不走微信 API）
# WECHAT_PAY_MOCK=true
