# Coze 工作流（必填，应用仅走真实 Coze 数据）
# 本地开发：复制为 .env.local
# Netlify 上线：只需配置 COZE_API_TOKEN（工作流 ID 已有默认值，可选覆盖）
#
# COZE_API_TOKEN=                    # 必填
# COZE_BASE_URL=https://api.coze.cn  # 可选
# COZE_WORKFLOW_CONTENT_STRATEGY=    # 可选，默认 7650520509235380264
# COZE_WORKFLOW_SCRIPT=              # 可选，默认 7650523558288719913
