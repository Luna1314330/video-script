# Coze 工作流（必填，应用仅走真实 Coze 数据）
# 本地开发：复制为 .env.local
# Netlify：Site configuration → Environment variables
#   - Scope 须包含 Builds 与 Functions（或选 All scopes）
#   - 保存后 Trigger deploy → Clear cache and deploy site
#
# COZE_API_TOKEN=
# COZE_BASE_URL=https://api.coze.cn
# COZE_WORKFLOW_CONTENT_STRATEGY=
# COZE_WORKFLOW_SCRIPT=
